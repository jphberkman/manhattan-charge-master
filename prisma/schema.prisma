// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projects  Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  messages  String   @default("[]")
  data      String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Hospital {
  id         String    @id @default(cuid())
  name       String
  address    String
  borough    String    @default("Manhattan")
  sourceFile String
  lastSeeded DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  prices     PriceEntry[]

  @@index([name])
}

model Procedure {
  id          String   @id @default(cuid())
  cptCode     String   @unique
  name        String
  category    String
  description String   @default("")

  prices      PriceEntry[]

  @@index([name])
  @@index([category])
}

model PriceEntry {
  id           String   @id @default(cuid())
  hospitalId   String
  procedureId  String
  payerName    String
  payerType    String
  priceInCents Int
  priceType    String
  rawCode      String   @default("")
  createdAt    DateTime @default(now())

  hospital     Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  procedure    Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@index([procedureId])
  @@index([procedureId, payerType])
  @@index([procedureId, payerType, priceType])
  @@index([hospitalId])
  @@index([hospitalId, procedureId])
  @@index([payerType, priceType])
  @@index([procedureId, priceType, priceInCents])
  @@index([hospitalId, payerType, priceType])
}

model CptCode {
  code        String   @id          // e.g. "27447"
  description String                // e.g. "Total knee replacement"
  category    String   @default("") // optional grouping
  /** CMS Medicare allowed amount (national avg, in USD). RVU-based benchmark. */
  medicareRate  Float?
  /** Average submitted charge (national avg, in USD). Chargemaster benchmark. */
  avgCharge     Float?
  /** Total Medicare services rendered nationally. Proxy for procedure frequency. */
  totalServices Float?
  createdAt   DateTime @default(now())

  @@index([description])
}

/// Maps common patient conditions/symptoms to the most appropriate CPT procedures.
/// Enables symptom-based search: "gallstones" → CPT 47562 (lap cholecystectomy).
model ConditionMapping {
  id          String   @id @default(cuid())
  /** Natural language condition or symptom (e.g. "gallstones", "torn ACL"). */
  condition   String
  /** ICD-10-CM code if applicable (e.g. "K80.2", "S83.51"). */
  icd10Code   String   @default("")
  /** Target CPT code for the most common treatment. */
  cptCode     String
  /** Procedure name for display. */
  procedureName String
  /** Relevance weight (higher = more common treatment for this condition). */
  weight      Int      @default(100)

  @@unique([condition, cptCode])
  @@index([condition])
  @@index([icd10Code])
  @@index([cptCode])
}

/// NUBC Revenue Codes — maps 4-digit facility charge categories to CPT procedures.
/// Hospitals often list facility fees by revenue code (e.g. 0360 = Operating Room)
/// rather than CPT code. This table links them for price aggregation.
model RevenueCode {
  code        String   @id          // e.g. "0360"
  description String                // e.g. "Operating Room Services"
  category    String   @default("") // e.g. "Facility", "Ancillary", "Accommodation"
  /** Related CPT code category (maps rev code to what type of charge it represents). */
  chargeType  String   @default("") // "facility" | "supply" | "pharmacy" | "room" | "diagnostic" | "therapy" | "other"
}
